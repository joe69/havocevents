<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- PDF-Ticket: oben das Event-Artwork, darunter die Infos,
         ein Ticket pro Seite. -->
    <template id="havoc_full_page_ticket" inherit_id="event.event_report_template_full_page_ticket">

        <!-- Artwork über den Ticket-Infos -->
        <xpath expr="//div[hasclass('o_event_full_page_ticket_details')]" position="before">
            <div style="text-align: center; page-break-inside: avoid; margin-bottom: 4mm;">
                <img src="/havoc_ticket_fee/static/img/ticket_poster.jpg"
                    style="max-width: 100%; max-height: 165mm;"
                    alt="HAVOC Event"/>
            </div>
        </xpath>

        <!-- Seitenumbruch nach jedem Ticket -->
        <xpath expr="//div[hasclass('o_event_full_page_ticket_wrapper')]" position="attributes">
            <attribute name="style">page-break-after: always;</attribute>
        </xpath>

        <!-- Datum/Uhrzeit je nach Tickettyp:
             Weekend = beide Tage, Freitag/Samstag = nur der jeweilige Tag.
             Achtung: Zeiten sind fix hinterlegt — bei neuem Event anpassen! -->
        <xpath expr="//i[hasclass('fa-calendar')]/ancestor::div[hasclass('o_event_full_page_ticket_column')]" position="replace">
            <div class="col-md-6 col-12 mb-3 o_event_full_page_ticket_column">
                <div class="d-flex">
                    <i class="fa fa-calendar fa-2x fa-fw me-2 mt-1"/>
                    <t t-set="havoc_ticket_name" t-value="(attendee and attendee.event_ticket_id.name or '').lower()"/>
                    <div t-if="'weekend' in havoc_ticket_name">
                        <span class="text-nowrap">18.09.2026 &#8211; 16:00&#8211;22:00 Uhr</span><br/>
                        <span class="text-nowrap">19.09.2026 &#8211; 15:00&#8211;22:00 Uhr</span>
                    </div>
                    <div t-elif="'freitag' in havoc_ticket_name">
                        <span class="text-nowrap">18.09.2026 &#8211; 16:00&#8211;22:00 Uhr</span>
                    </div>
                    <div t-elif="'samstag' in havoc_ticket_name">
                        <span class="text-nowrap">19.09.2026 &#8211; 15:00&#8211;22:00 Uhr</span>
                    </div>
                    <div t-else="">
                        <span t-field="event.date_begin" class="text-nowrap"
                            t-options='{"widget": "datetime", "tz_name": event.date_tz, "format": "short"}'/><br/>
                        <span class="me-1">bis</span><span t-field="event.date_end" class="text-nowrap"
                            t-options='{"widget": "datetime", "tz_name": event.date_tz, "format": "short"}'/>
                    </div>
                </div>
            </div>
        </xpath>

    </template>

</odoo>
