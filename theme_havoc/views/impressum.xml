<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Impressum-Seite (Inhalt im Website-Editor bearbeitbar) -->
    <template id="impressum_page" name="Impressum">
        <t t-call="website.layout">
            <t t-set="additional_title">Impressum</t>
            <div id="wrap" class="th_impressum">
                <div class="oe_structure" id="oe_structure_theme_havoc_impressum">
                    <section class="py-5">
                        <div class="container" style="max-width: 720px;">
                            <h1 class="mb-4">Impressum</h1>
                            <p class="text-muted">
                                Angaben gemäß &#167; 5 E-Commerce-Gesetz (ECG),
                                &#167; 14 UGB und &#167; 25 Mediengesetz
                            </p>

                            <h5 class="mt-4">Betreiber der Website &amp; Ticketverkauf</h5>
                            <p>
                                IT - Dienstleistung Entlicher KG<br/>
                                Alois Wonisch Weg 17<br/>
                                8401 Kalsdorf<br/>
                                Österreich
                            </p>

                            <h5 class="mt-4">Markenrechte</h5>
                            <p>
                                Die Marke <strong>HAVOC</strong> steht im Eigentum der<br/>
                                Havoc Entertainment e.U.<br/>
                                Liebenauer Hauptstraße 95a/20<br/>
                                8041 Graz<br/>
                                Österreich
                            </p>

                            <h5 class="mt-4">Kontakt</h5>
                            <p>
                                E-Mail: <a href="mailto:office@havoc.events">office@havoc.events</a>
                            </p>
                        </div>
                    </section>
                </div>
            </div>
        </t>
    </template>

    <!-- Impressum-Link inline in der Copyright-Zeile, mit Trenner -->
    <template id="footer_impressum_link" inherit_id="website.layout" name="Footer Impressum Link">
        <xpath expr="//div[hasclass('o_footer_copyright')]//div[hasclass('col-sm')]" position="inside">
            <span class="mx-2">|</span><a href="/impressum">Impressum</a>
        </xpath>
    </template>

</odoo>
